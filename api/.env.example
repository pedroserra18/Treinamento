NODE_ENV=development
API_PORT=4000
CLIENT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
REDIS_URL=redis://localhost:6379

# Request protection
GLOBAL_RATE_LIMIT_MAX=100
LOGIN_BRUTE_FORCE_MAX=5
LOGIN_BRUTE_FORCE_WINDOW_MIN=15
LOGIN_PROGRESSIVE_BASE_MIN=5
LOGIN_PROGRESSIVE_MAX_MIN=60
OAUTH_STATE_TTL_MIN=10

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acad_dev?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/acad_dev?schema=public

# JWT (Access + Refresh)
JWT_SECRET=replace_with_strong_access_secret_min_32_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=acad-api
JWT_AUDIENCE=acad-web

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# Monitoring / Observability
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=acad-api
