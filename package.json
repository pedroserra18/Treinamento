{
  "name": "acad",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:api": "npm --prefix api run dev",
    "dev:full": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build": "next build",
    "build:web": "next build",
    "build:api": "npm --prefix api run build",
    "typecheck:web": "tsc -p tsconfig.json --noEmit",
    "typecheck:api": "npm --prefix api run typecheck",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "lint:web": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-pattern api/**",
    "lint:api": "eslint api/src --ext .ts",
    "lint": "npm run lint:web && npm run lint:api",
    "db:generate": "npm --prefix api run prisma:generate",
    "db:validate": "npm --prefix api run prisma:validate",
    "db:migrate": "npm --prefix api run prisma:migrate:dev --",
    "db:seed": "npm --prefix api run prisma:seed",
    "db:studio": "npm --prefix api run prisma:studio",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "start": "next start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^7.6.0",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.8.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@prisma/internals": "^7.6.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/express": "^5.0.3",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "prettier": "^3.6.2",
    "prisma": "^7.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "6.0.2"
  }
