{
  "name": "acad",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:full",
    "dev:web": "npm --prefix frontend-vite run dev",
    "dev:api": "npm --prefix api run dev",
    "dev:full": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm --prefix frontend-vite run build",
    "build:api": "npm --prefix api run build",
    "lint:web": "npm --prefix frontend-vite run lint",
    "lint:api": "eslint --config api/eslint.config.mjs api/src --ext .ts --max-warnings=0",
    "lint": "npm run lint:web && npm run lint:api",
    "typecheck:web": "npm --prefix frontend-vite exec -- tsc -b frontend-vite/tsconfig.json",
    "typecheck:api": "npm --prefix api run typecheck",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "db:generate": "npm --prefix api run prisma:generate",
    "db:validate": "npm --prefix api run prisma:validate",
    "db:migrate": "npm --prefix api run prisma:migrate:dev --",
    "db:seed": "npm --prefix api run prisma:seed",
    "db:studio": "npm --prefix api run prisma:studio",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "test": "npm --prefix api run test:integration"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/express": "^5.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2"
  }
}
